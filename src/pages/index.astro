---
const email = 'nishanth@eetaa.tech';
const address = {
  line1: '1111B S Governors Ave # 97523',
  line2: 'Dover, DE 19904',
};

const products = [
  {
    num: '01',
    name: 'Skia',
    url: 'https://skia.io',
    domain: 'skia.io',
    tagline: 'Quality assurance for every radiology report',
    description:
      'Skia validates every report before it leaves the group - laterality, comparison dates, contradictions, missing impressions, client-specific rules - while coordinating the workflow from worklist assignment through PACS submission and standardizing report structure across the whole team.',
  },
  {
    num: '02',
    name: 'RadMyk',
    url: 'https://radmyk.com',
    domain: 'radmyk.com',
    tagline: 'Dictation radiologists own, not rent',
    description:
      'RadMyk turns speech into text in real time, entirely on-device - no cloud, no account, no internet required. It types directly into any application on Windows and macOS, and residents in training use it free.',
  },
];

const services = [
  {
    num: '01',
    title: 'Building technology',
    description:
      'End-to-end product engineering: we design, build, and ship software - from internal tools to full platforms - and stay on to run them.',
  },
  {
    num: '02',
    title: 'Radiology workflow optimization',
    description:
      'We study how studies actually move through your practice - worklists, assignment, reporting, QA, submission - and remove the friction at each step.',
  },
  {
    num: '03',
    title: 'AI for radiology groups',
    description:
      'We integrate AI into the daily work of radiology groups - report drafting, quality checks, triage, coordination - enhancing radiologists rather than replacing their judgment.',
  },
  {
    num: '04',
    title: 'AI for any organization',
    description:
      'The same discipline, applied anywhere: we map your workflow, find where AI genuinely helps, and wire it in so your team feels the difference in a week, not a year.',
  },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Eetaa, Inc.',
  legalName: 'Eetaa, Inc.',
  url: 'https://eetaa.tech',
  email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: address.line1,
    addressLocality: 'Dover',
    addressRegion: 'DE',
    postalCode: '19904',
    addressCountry: 'US',
  },
  brand: [
    { '@type': 'Brand', name: 'Skia', url: 'https://skia.io' },
    { '@type': 'Brand', name: 'RadMyk', url: 'https://radmyk.com' },
  ],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Eetaa, Inc. - Software and AI for radiology</title>
    <meta
      name="description"
      content="Eetaa, Inc. builds software that makes teams efficient - Skia for radiology workflow coordination and report QA, RadMyk for on-device dictation - and helps organizations put AI to work."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://eetaa.tech/" />
    <meta property="og:title" content="Eetaa, Inc. - Software and AI for radiology" />
    <meta
      property="og:description"
      content="Eetaa, Inc. builds software that makes teams efficient - Skia for radiology workflow coordination and report QA, RadMyk for on-device dictation - and helps organizations put AI to work."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://eetaa.tech/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600&family=Fragment+Mono&family=Fraunces:ital,opsz,wght@0,9..144,340..640;1,9..144,340..640&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={jsonLd} />
  </head>

  <body>
    <div class="rule-top"></div>

    <header class="shell nav">
      <a class="wordmark" href="/">Eetaa<span class="wordmark-dot">.</span></a>
      <nav class="nav-links" aria-label="Main">
        <a href="#products">Products</a>
        <a href="#services">Services</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <!-- ============ HERO ============ -->
      <section class="shell hero">
        <p class="kicker rise" style="--d: 0">Eetaa, Inc. &mdash; Dover, Delaware</p>
        <h1 class="rise" style="--d: 1">
          Efficiency,<br />
          <em>engineered</em>.
        </h1>
        <p class="lede rise" style="--d: 2">
          Eetaa builds software that makes you and your team efficient - products
          that run radiology end to end, and AI put to work inside any
          organization's workflow.
        </p>
        <div class="hero-actions rise" style="--d: 3">
          <a class="btn btn-solid" href={`mailto:${email}`}>Get in touch</a>
          <a class="btn btn-ghost" href="#products">See our products</a>
        </div>
        <div class="hero-marks" aria-hidden="true">
          <span class="cross c1">+</span>
          <span class="cross c2">+</span>
          <span class="cross c3">+</span>
        </div>
      </section>

      <!-- ============ PRODUCTS ============ -->
      <section id="products" class="shell section">
        <div class="section-head reveal">
          <span class="index">A</span>
          <h2>Products</h2>
          <p class="section-note">Two products, both born inside radiology practices.</p>
        </div>

        <div class="product-list">
          {
            products.map((p) => (
              <article class="product reveal">
                <div class="product-meta">
                  <span class="mono">{p.num}</span>
                  <a class="domain mono" href={p.url} target="_blank" rel="noopener">
                    {p.domain} &nearr;
                  </a>
                </div>
                <div class="product-body">
                  <h3>
                    <a href={p.url} target="_blank" rel="noopener">
                      {p.name}
                    </a>
                  </h3>
                  <p class="product-tagline">{p.tagline}</p>
                  <p class="product-desc">{p.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <!-- ============ SERVICES ============ -->
      <section id="services" class="shell section">
        <div class="section-head reveal">
          <span class="index">B</span>
          <h2>Services</h2>
          <p class="section-note">
            For radiology groups and any organization ready to work differently.
          </p>
        </div>

        <div class="service-grid">
          {
            services.map((s) => (
              <article class="service reveal">
                <span class="mono service-num">{s.num}</span>
                <h3>{s.title}</h3>
                <p>{s.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- ============ CONTACT ============ -->
      <section id="contact" class="shell section contact">
        <div class="section-head reveal">
          <span class="index">C</span>
          <h2>Contact</h2>
        </div>
        <div class="contact-body reveal">
          <p class="contact-lede">
            Working on something in radiology &mdash; or a workflow that AI should
            already be part of? <em>Write to us.</em>
          </p>
          <a class="contact-email" href={`mailto:${email}`}>{email}</a>
          <address class="mono">
            Eetaa, Inc.<br />
            {address.line1}<br />
            {address.line2}<br />
            United States
          </address>
        </div>
      </section>
    </main>

    <footer class="shell footer">
      <p class="mono">&copy; {new Date().getFullYear()} Eetaa, Inc. All rights reserved.</p>
      <p class="mono footer-addr">
        {address.line1}, {address.line2} &middot; <a href={`mailto:${email}`}>{email}</a>
      </p>
    </footer>

    <style>
      :root {
        --paper: #f4f1e9;
        --paper-deep: #ece8dd;
        --ink: #1d1a13;
        --ink-soft: #5d5644;
        --line: rgba(29, 26, 19, 0.16);
        --accent: #1b5245;
        --accent-ink: #123b31;
        --serif: 'Fraunces', georgia, serif;
        --sans: 'Archivo', helvetica, sans-serif;
        --mono: 'Fragment Mono', monospace;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background:
          radial-gradient(1200px 600px at 85% -10%, rgba(27, 82, 69, 0.07), transparent 60%),
          var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 17px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      ::selection {
        background: var(--accent);
        color: var(--paper);
      }

      .rule-top {
        height: 4px;
        background: var(--accent);
      }

      .shell {
        max-width: 1060px;
        margin-inline: auto;
        padding-inline: clamp(20px, 5vw, 48px);
      }

      .mono {
        font-family: var(--mono);
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--ink-soft);
        font-style: normal;
      }

      /* ---------- nav ---------- */
      .nav {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding-block: 26px;
      }

      .wordmark {
        font-family: var(--serif);
        font-size: 1.55rem;
        font-weight: 560;
        color: var(--ink);
        text-decoration: none;
        letter-spacing: -0.01em;
      }

      .wordmark-dot {
        color: var(--accent);
      }

      .nav-links {
        display: flex;
        gap: clamp(16px, 3vw, 34px);
      }

      .nav-links a {
        font-family: var(--mono);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--ink-soft);
        text-decoration: none;
        padding-bottom: 2px;
        border-bottom: 1px solid transparent;
        transition: color 0.2s, border-color 0.2s;
      }

      .nav-links a:hover {
        color: var(--accent-ink);
        border-color: var(--accent);
      }

      /* ---------- hero ---------- */
      .hero {
        position: relative;
        padding-block: clamp(70px, 12vh, 130px) clamp(80px, 12vh, 130px);
      }

      .kicker {
        font-family: var(--mono);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent-ink);
        margin-bottom: 26px;
      }

      .kicker::before {
        content: '';
        display: inline-block;
        width: 34px;
        height: 1px;
        background: var(--accent);
        vertical-align: middle;
        margin-right: 12px;
      }

      h1 {
        font-family: var(--serif);
        font-weight: 470;
        font-size: clamp(2.6rem, 7.2vw, 5.1rem);
        line-height: 1.04;
        letter-spacing: -0.022em;
        max-width: 14ch;
      }

      h1 em {
        font-style: italic;
        font-weight: 420;
        color: var(--accent);
      }

      .lede {
        margin-top: 28px;
        max-width: 52ch;
        font-size: clamp(1.05rem, 1.6vw, 1.2rem);
        color: var(--ink-soft);
      }

      .hero-actions {
        margin-top: 40px;
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .btn {
        font-family: var(--mono);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-decoration: none;
        padding: 14px 26px;
        border-radius: 999px;
        transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
      }

      .btn:active {
        transform: translateY(1px);
      }

      .btn-solid {
        background: var(--accent);
        color: var(--paper);
        border: 1px solid var(--accent);
      }

      .btn-solid:hover {
        background: var(--accent-ink);
      }

      .btn-ghost {
        color: var(--ink);
        border: 1px solid var(--line);
      }

      .btn-ghost:hover {
        border-color: var(--ink);
      }

      .hero-marks .cross {
        position: absolute;
        font-family: var(--mono);
        color: var(--accent);
        opacity: 0.55;
        font-size: 1rem;
        user-select: none;
      }

      .cross.c1 { top: 18%; right: 8%; }
      .cross.c2 { top: 62%; right: 22%; }
      .cross.c3 { bottom: 8%; left: 46%; }

      /* ---------- sections ---------- */
      .section {
        padding-block: clamp(56px, 9vh, 96px);
        border-top: 1px solid var(--line);
        position: relative;
      }

      .section::before,
      .section::after {
        content: '+';
        position: absolute;
        top: -0.72em;
        font-family: var(--mono);
        font-size: 0.9rem;
        color: var(--ink-soft);
        background: transparent;
      }

      .section::before { left: clamp(20px, 5vw, 48px); }
      .section::after { right: clamp(20px, 5vw, 48px); }

      .section-head {
        display: flex;
        align-items: baseline;
        gap: 18px;
        flex-wrap: wrap;
        margin-bottom: clamp(36px, 6vh, 56px);
      }

      .index {
        font-family: var(--mono);
        font-size: 0.78rem;
        color: var(--paper);
        background: var(--ink);
        width: 26px;
        height: 26px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transform: translateY(-3px);
      }

      h2 {
        font-family: var(--serif);
        font-weight: 500;
        font-size: clamp(1.9rem, 3.6vw, 2.6rem);
        letter-spacing: -0.015em;
      }

      .section-note {
        color: var(--ink-soft);
        font-size: 0.95rem;
        margin-left: auto;
        max-width: 34ch;
      }

      /* ---------- products ---------- */
      .product-list {
        display: flex;
        flex-direction: column;
      }

      .product {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 24px;
        padding-block: 38px;
        border-top: 1px solid var(--line);
      }

      .product:first-child {
        border-top: none;
        padding-top: 0;
      }

      .product-meta {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .domain {
        text-decoration: none;
        color: var(--accent-ink);
        transition: color 0.2s;
      }

      .domain:hover {
        color: var(--accent);
      }

      .product h3 {
        font-family: var(--serif);
        font-size: clamp(1.8rem, 3.4vw, 2.4rem);
        font-weight: 520;
        letter-spacing: -0.015em;
        line-height: 1.1;
      }

      .product h3 a {
        color: var(--ink);
        text-decoration: none;
        background-image: linear-gradient(var(--accent), var(--accent));
        background-repeat: no-repeat;
        background-size: 0% 2px;
        background-position: 0 96%;
        transition: background-size 0.28s ease;
      }

      .product h3 a:hover {
        background-size: 100% 2px;
      }

      .product-tagline {
        margin-top: 8px;
        font-family: var(--serif);
        font-style: italic;
        font-size: 1.12rem;
        color: var(--accent-ink);
      }

      .product-desc {
        margin-top: 14px;
        max-width: 58ch;
        color: var(--ink-soft);
      }

      /* ---------- services ---------- */
      .service-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
      }

      .service {
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        padding: clamp(24px, 4vw, 38px);
        background: transparent;
        transition: background 0.25s ease;
      }

      .service:hover {
        background: var(--paper-deep);
      }

      .service-num {
        color: var(--accent-ink);
      }

      .service h3 {
        font-family: var(--serif);
        font-weight: 520;
        font-size: 1.35rem;
        letter-spacing: -0.01em;
        margin-top: 14px;
      }

      .service p {
        margin-top: 10px;
        color: var(--ink-soft);
        font-size: 0.96rem;
        max-width: 44ch;
      }

      /* ---------- contact ---------- */
      .contact-lede {
        font-family: var(--serif);
        font-size: clamp(1.5rem, 3vw, 2.1rem);
        font-weight: 460;
        line-height: 1.3;
        letter-spacing: -0.015em;
        max-width: 26ch;
      }

      .contact-lede em {
        color: var(--accent);
      }

      .contact-email {
        display: inline-block;
        margin-top: 34px;
        font-family: var(--mono);
        font-size: clamp(1rem, 2.4vw, 1.4rem);
        color: var(--ink);
        text-decoration: none;
        border-bottom: 2px solid var(--accent);
        padding-bottom: 4px;
        transition: color 0.2s;
      }

      .contact-email:hover {
        color: var(--accent-ink);
      }

      .contact-body address {
        margin-top: 40px;
        line-height: 2;
      }

      /* ---------- footer ---------- */
      .footer {
        border-top: 1px solid var(--line);
        padding-block: 28px 40px;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
      }

      .footer a {
        color: inherit;
      }

      .footer .mono {
        text-transform: none;
        letter-spacing: 0.02em;
      }

      /* ---------- motion ---------- */
      .rise {
        opacity: 0;
        transform: translateY(18px);
        animation: rise 0.7s cubic-bezier(0.2, 0.65, 0.25, 1) forwards;
        animation-delay: calc(var(--d) * 0.12s + 0.05s);
      }

      @keyframes rise {
        to {
          opacity: 1;
          transform: none;
        }
      }

      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity 0.65s ease, transform 0.65s cubic-bezier(0.2, 0.65, 0.25, 1);
      }

      .reveal.in {
        opacity: 1;
        transform: none;
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        .rise { animation: none; opacity: 1; transform: none; }
        .reveal { transition: none; opacity: 1; transform: none; }
      }

      /* ---------- responsive ---------- */
      @media (max-width: 720px) {
        .product {
          grid-template-columns: 1fr;
          gap: 12px;
        }

        .product-meta {
          flex-direction: row;
          justify-content: space-between;
          align-items: baseline;
        }

        .service-grid {
          grid-template-columns: 1fr;
        }

        .section-note {
          margin-left: 44px;
          flex-basis: 100%;
        }

        .hero-marks { display: none; }
      }
    </style>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
